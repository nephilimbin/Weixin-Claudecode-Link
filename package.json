{
  "name": "weixin-claudecode-link",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "wxcc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --max-old-space-size=8192 --import tsx src/index.ts",
    "link": "npm run build && npm link",
    "unlink": "npm unlink -g wxcc",
    "install-global": "npm run build && npm install -g .",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "pino": "^10.1.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
